# --- Agent Configuration (OpenAI-compatible) ---
# The base URL for the API. Hugging Face Router is the default for this competition.
OPEN_AI_BASE_URL=https://router.huggingface.co/v1

# The name of the model to evaluate (e.g., Qwen/Qwen2.5-72B-Instruct)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# --- Hugging Face Configuration ---
# Your Hugging Face User Access Token (used as fallback for API_KEY if needed)
HF_TOKEN=your_hugging_face_token_here

# --- Environment Configuration ---
# The URL where your environment server is running (e.g., HF Space URL)
HF_SPACE_URL=http://localhost:7860

# The task variant to run (identify_bug, suggest_fix, full_review)
CODE_REVIEW_TASK=identify_bug
